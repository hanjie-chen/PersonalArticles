#!/usr/bin/env python3
# -*- coding: utf-8 -*-

import os
import subprocess
import sys
from pathlib import Path


HOOK_DIR = Path(__file__).resolve().parent
SCRIPT_DIR = HOOK_DIR / "pre-commit.d"
REVIEW_NEEDED = 2


def command_for(script_path: Path) -> list[str]:
    if script_path.suffix == ".py":
        return [sys.executable, str(script_path)]
    return [str(script_path)]


def iter_hook_scripts() -> list[Path]:
    if not SCRIPT_DIR.is_dir():
        return []
    return [
        item
        for item in sorted(SCRIPT_DIR.iterdir())
        if item.is_file() and not item.name.startswith(".")
    ]


def main() -> int:
    review_needed = False
    scripts = iter_hook_scripts()

    if not scripts:
        return 0

    print("[pre-commit]", flush=True)
    for index, script_path in enumerate(scripts):
        is_last_script = index == len(scripts) - 1
        script_prefix = "└─" if is_last_script else "├─"
        child_prefix = "   " if is_last_script else "│  "

        print(f"{script_prefix} {script_path.name}", flush=True)
        result = subprocess.run(
            command_for(script_path),
            check=False,
            env={
                **os.environ,
                "GITHOOK_LOG_ITEM_PREFIX": f"{child_prefix}├─ ",
                "GITHOOK_LOG_LAST_PREFIX": f"{child_prefix}└─ ",
                "GITHOOK_LOG_DETAIL_PREFIX": f"{child_prefix}│  ├─ ",
            },
        )
        if result.returncode == REVIEW_NEEDED:
            review_needed = True
            continue
        if result.returncode != 0:
            print(
                f"[pre-commit] failed: {script_path.name} exited with status "
                f"{result.returncode}",
                flush=True,
            )
            return result.returncode

    if review_needed:
        print("", flush=True)
        print("[pre-commit] review required: generated changes were staged", flush=True)
        return 1

    return 0


if __name__ == "__main__":
    raise SystemExit(main())
